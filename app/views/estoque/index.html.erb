  <div class="mb-8 flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Estoque</h1>
      <p class="mt-2 text-gray-600">Gerencie o estoque de produtos</p>
    </div>
    <%= link_to new_estoque_path, class: "inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
      </svg>
      Novo Produto
    <% end %>
  </div>

  <!-- Alertas de Estoque Baixo -->
  <% if @produtos_baixo_estoque.any? %>
    <div class="mb-6 bg-red-50 border-l-4 border-red-400 p-4 rounded-lg">
      <div class="flex">
        <div class="ml-3">
          <p class="text-sm font-medium text-red-800">
            <strong><%= @produtos_baixo_estoque.count %></strong> produto(s) com estoque baixo!
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Filtros -->
  <div class="mb-6 flex gap-4 flex-wrap">
    <%= form_with url: estoque_index_path, method: :get, local: true, class: "flex gap-4 flex-1" do |f| %>
      <%= f.text_field :busca, 
          value: params[:busca],
          placeholder: "Buscar produtos...",
          class: "flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500" %>
      <%= f.select :categoria, 
          options_for_select([["Todas as categorias", ""]] + @categorias.map { |c| [c, c] }, params[:categoria]),
          {},
          { class: "px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500" } %>
      <%= f.submit "Filtrar", class: "px-6 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition" %>
      <% if params[:busca].present? || params[:categoria].present? %>
        <%= link_to "Limpar", estoque_index_path, class: "px-6 py-2 bg-gray-300 text-gray-700 rounded-lg hover:bg-gray-400 transition" %>
      <% end %>
    <% end %>
  </div>

  <!-- Tabela de Produtos -->
  <div class="bg-white rounded-xl shadow-md overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Produto</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Categoria</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Quantidade</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Preço</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ações</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @produtos.any? %>
            <% @produtos.each do |produto| %>
              <tr class="hover:bg-gray-50 <%= 'bg-red-50' if produto.estoque_baixo? %>">
                <td class="px-6 py-4">
                  <div class="text-sm font-medium text-gray-900"><%= produto.nome %></div>
                  <% if produto.descricao.present? %>
                    <div class="text-sm text-gray-500"><%= truncate(produto.descricao, length: 50) %></div>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="px-2 py-1 text-xs font-medium bg-blue-100 text-green-800 rounded-full">
                    <%= produto.categoria || "Sem categoria" %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= produto.quantidade %></div>
                  <div class="text-xs text-gray-500">Mín: <%= produto.valor_minimo %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= format_currency(produto.preco) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if produto.estoque_baixo? %>
                    <span class="px-2 py-1 text-xs font-medium bg-red-100 text-red-800 rounded-full">Estoque Baixo</span>
                  <% else %>
                    <span class="px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Normal</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-2">
                    <%= link_to estoque_path(produto), class: "text-green-600 hover:text-green-900" do %>
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    <% end %>
                    <%= link_to edit_estoque_path(produto), class: "text-yellow-600 hover:text-yellow-900" do %>
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                    <% end %>
                    <%= link_to estoque_path(produto), method: :delete, 
                        data: { confirm: "Tem certeza que deseja excluir este produto?" },
                        class: "text-red-600 hover:text-red-900" do %>
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                <p>Nenhum produto encontrado</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
