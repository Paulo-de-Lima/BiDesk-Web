  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Nova Transação</h1>
    <p class="mt-2 text-gray-600">Registre uma nova transação financeira</p>
  </div>

  <div class="bg-white rounded-xl shadow-md p-8">
    <%= form_with model: @transacao, url: financeiro_index_path, local: true, class: "space-y-6" do |f| %>
      <% if @transacao.errors.any? %>
        <div class="bg-red-50 border-l-4 border-red-400 p-4">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% @transacao.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :tipo, "Tipo *", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :tipo, 
            options_for_select([["Receita", "receita"], ["Despesa", "despesa"]], @transacao.tipo),
            {},
            { class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500",
              required: true } %>
      </div>

      <div>
        <%= f.label :descricao, "Descrição *", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :descricao, 
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500",
            required: true %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :valor, "Valor *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.number_field :valor, 
              step: 0.01,
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500",
              min: 0.01,
              required: true %>
        </div>

        <div>
          <%= f.label :data, "Data *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.date_field :data, 
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500",
              required: true %>
        </div>
      </div>

      <div>
        <%= f.label :categoria, "Categoria *", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :categoria, 
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500",
            placeholder: "Ex: Vendas, Aluguel, Manutenção",
            required: true %>
      </div>

      <div class="flex justify-end space-x-4 pt-4">
        <%= link_to "Cancelar", financeiro_index_path, class: "px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition" %>
        <%= f.submit "Salvar", class: "px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition" %>
      </div>
    <% end %>
  </div>
</div>
