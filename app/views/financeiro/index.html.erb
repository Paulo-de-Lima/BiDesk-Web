  <div class="mb-8 flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Financeiro</h1>
      <p class="mt-2 text-gray-600">Controle financeiro da empresa</p>
    </div>
    <%= link_to new_financeiro_path, class: "inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
      </svg>
      Nova Transação
    <% end %>
  </div>

  <!-- Resumo Financeiro -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
      <p class="text-sm font-medium text-gray-600">Receitas do Mês</p>
      <p class="text-3xl font-bold text-green-600 mt-2"><%= format_currency(@receitas_mes) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-red-500">
      <p class="text-sm font-medium text-gray-600">Despesas do Mês</p>
      <p class="text-3xl font-bold text-red-600 mt-2"><%= format_currency(@despesas_mes) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
      <p class="text-sm font-medium text-gray-600">Saldo do Mês</p>
      <p class="text-3xl font-bold <%= @saldo_mes >= 0 ? 'text-green-600' : 'text-red-600' %> mt-2">
        <%= format_currency(@saldo_mes) %>
      </p>
    </div>
  </div>

  <!-- Filtros -->
  <div class="mb-6 flex gap-4 flex-wrap">
    <%= form_with url: financeiro_index_path, method: :get, local: true, class: "flex gap-4 flex-1" do |f| %>
      <%= f.select :tipo, 
          options_for_select([["Todos", ""], ["Receitas", "receita"], ["Despesas", "despesa"]], params[:tipo]),
          {},
          { class: "px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500" } %>
      <%= f.select :categoria, 
          options_for_select([["Todas as categorias", ""]] + @categorias.map { |c| [c, c] }, params[:categoria]),
          {},
          { class: "px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500" } %>
      <%= f.submit "Filtrar", class: "px-6 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition" %>
      <% if params[:tipo].present? || params[:categoria].present? %>
        <%= link_to "Limpar", financeiro_index_path, class: "px-6 py-2 bg-gray-300 text-gray-700 rounded-lg hover:bg-gray-400 transition" %>
      <% end %>
    <% end %>
  </div>

  <!-- Tabela de Transações -->
  <div class="bg-white rounded-xl shadow-md overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Data</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Descrição</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Categoria</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Valor</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ações</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @transacoes.any? %>
            <% @transacoes.each do |transacao| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= format_date(transacao.data) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="px-2 py-1 text-xs font-medium rounded-full <%= transacao.tipo == 'receita' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                    <%= transacao.tipo == 'receita' ? 'Receita' : 'Despesa' %>
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-gray-900"><%= transacao.descricao %></td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="px-2 py-1 text-xs font-medium bg-blue-100 text-green-800 rounded-full">
                    <%= transacao.categoria %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-bold <%= transacao.tipo == 'receita' ? 'text-green-600' : 'text-red-600' %>">
                  <%= transacao.tipo == 'receita' ? '+' : '-' %><%= format_currency(transacao.valor) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-2">
                    <%= link_to financeiro_path(transacao), class: "text-green-600 hover:text-green-900" do %>
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    <% end %>
                    <%= link_to edit_financeiro_path(transacao), class: "text-yellow-600 hover:text-yellow-900" do %>
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                    <% end %>
                    <%= button_to financeiro_path(transacao),
                        method: :delete,
                        data: { turbo_confirm: "Tem certeza que deseja excluir esta movimentação?" },
                        form: { class: "inline" },
                        class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 cursor-pointer" do %>
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                <p>Nenhuma transação encontrada</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
