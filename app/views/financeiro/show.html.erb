<div class="mb-8 flex justify-between items-center">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Detalhes da Movimentação</h1>
    <p class="mt-2 text-gray-600">Informações completas desta movimentação financeira</p>
  </div>
  <div class="flex space-x-3">
    <%= link_to edit_financeiro_path(@transacao), class: "inline-flex items-center px-4 py-2 bg-yellow-600 text-white rounded-lg hover:bg-yellow-700 transition" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
      </svg>
      Editar
    <% end %>
    <%= link_to financeiro_index_path, class: "inline-flex items-center px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition" do %>
      Voltar
    <% end %>
  </div>
</div>

<div class="bg-white rounded-xl shadow-md p-8">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label class="block text-sm font-medium text-gray-500 mb-1">Tipo</label>
      <span class="inline-block px-2 py-1 text-xs font-medium rounded-full <%= @transacao.tipo == 'receita' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
        <%= @transacao.tipo == "receita" ? "Receita" : "Despesa" %>
      </span>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-500 mb-1">Data</label>
      <p class="text-lg font-semibold text-gray-900"><%= format_date(@transacao.data) %></p>
    </div>
    <div class="md:col-span-2">
      <label class="block text-sm font-medium text-gray-500 mb-1">Descrição</label>
      <p class="text-lg font-semibold text-gray-900"><%= @transacao.descricao %></p>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-500 mb-1">Categoria</label>
      <p class="text-lg font-semibold text-gray-900"><%= @transacao.categoria %></p>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-500 mb-1">Valor</label>
      <p class="text-2xl font-bold <%= @transacao.tipo == 'receita' ? 'text-green-600' : 'text-red-600' %>">
        <%= @transacao.tipo == "receita" ? "+" : "-" %><%= format_currency(@transacao.valor) %>
      </p>
    </div>
  </div>
</div>
